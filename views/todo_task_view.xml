<odoo>
    <record id = 'todo_task_tree_view' model = 'ir.ui.view'>
        <field name = 'name'>todo task view</field>
        <field name = 'model'>todo.task</field>
        <field name = 'arch' type = 'xml'>
            <tree>
                <field name = 'name'/>
                <field name = 'assign_to'/>
                <field name = 'due_date'/>
                <field name = 'status'/>
                <field name = 'description'/>
            </tree>
        </field>
    </record>

    <record id = 'todo_task_form_view' model = 'ir.ui.view'>
        <field name = 'name'>todo task view</field>
        <field name = 'model'>todo.task</field>
        <field name = 'arch' type = 'xml'>
            <form>
                <sheet>
                    <header>
                        <button name = 'action_new' type = 'object' class = 'btn-primary' string = 'Set To New'/>
                        <button name = 'action_in_progress' type = 'object' class = 'btn-secondry' string = 'Set It In Progress'/>
                        <button name = 'action_completed' type = 'object' class = 'btn-success' string = 'Set To Completed'/>
                        <field name = 'status' widget = 'statusbar'/>
                    </header>
                    <div class = 'oe_title'>
                        <label for = 'name'/>
                        <h1>
                            <field name = 'name'/>
                        </h1>
                    </div>
                    <group>
                        <group string = 'General Info'>
                            <field name = 'assign_to'/>
                            <field name = 'due_date'/>
                        </group>
                    </group>
                    <group>
                        <field name = 'description'/>
                    </group>
                </sheet>
                <div class = 'oe_chatter'>
                    <field name = 'message_follower_ids'/>
                    <field name = 'activity_ids'/>
                    <field name = 'message_ids'/>
                </div>
            </form>
        </field>
    </record>

    <record id = 'todo_task_search_view' model = 'ir.ui.view'>
        <field name = 'name'>todo task view</field>
        <field name = 'model'>todo.task</field>
        <field name = 'arch' type = 'xml'>
            <search>
                <field name = 'name'/>
                <field name = 'assign_to'/>

                <filter name = 'is_new' string = 'New' domain = "[('status' , '=' , 'new')]"/>
                <filter name = 'In_progress' string = 'In Progress' domain = "[('status' , '=' , 'in_progress')]"/>
                <filter name = 'is_completed' string = 'Completed' domain = "[('status' , '=' , 'completed')]"/>

                <filter name = 'group_by_assign_to' string = ' Group by Assign To' context = "{'group_by': 'assign_to'}"/>
                <filter name = 'group_by_status' string = 'Group by Status' context = "{'group_by':'status'}"/>
                <filter name = 'group_by_due_date' string = 'Group by Due Date' context = "{'group_by':'due_date'}"/>
            </search>
        </field>
    </record>

    <record id = 'todo_task_action' model = 'ir.actions.act_window'>
        <field name = 'name'>Todo Task Action</field>
        <field name = 'res_model'>todo.task</field>
    </record>

    <menuitem
    id = 'todo_task_menuitem'
    name = 'Todo Tasks'
    parent = 'menu_todo_all_tasks'
    action = 'todo_task_action'
    />
</odoo>